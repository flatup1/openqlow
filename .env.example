# OPENQLOW never publishes directly in Phase 1.
OPENQLOW_ROOT=/Users/jin/Desktop/OPENQLOW HelMES/openqlow
FLATUP_AI_OS_ROOT=/Users/jin/Desktop/OPENQLOW HelMES/flatup-ai-os
OBSIDIAN_VAULT_ROOT=/Users/jin/Documents/Obsidian Vault
OPENQLOW_INBOX_RELATIVE=30_INBOX/openqlow
OPENQLOW_LINE_PORT=8787
OPENQLOW_DRY_RUN=true
OPENQLOW_LINE_DRY_RUN=false
OPENQLOW_PUBLIC_WEBHOOK_URL=

# LLM
OPENROUTER_API_KEY=

# LINE webhook（Do not commit real secrets）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
JIN_LINE_USER_ID=
BACKUP_APPROVER_LINE_USER_ID=

# SNS 配信
THREADS_ACCESS_TOKEN=
IG_ACCESS_TOKEN=
FB_PAGE_TOKEN=
GOOGLE_BUSINESS_ACCESS_TOKEN=

# Typefully config is read from the existing local config, never stored here.
TYPEFULLY_CONFIG_PATH=/Users/jin/.config/typefully/config.json

# 体験後フォロー自動化（TASK E / scheduler: trial_followup_scheduler）
# 既定は「Jin の LINE に確認用ドラフトを送る」= 顧客へは自動送信しない（承認ゲート順守）。
# 顧客へ AIKA が直接自動送信してよくなったら true にする。
OPENQLOW_TRIAL_FOLLOWUP_AUTO_SEND=false
# 完全停止したいとき true。
OPENQLOW_TRIAL_FOLLOWUP_DISABLED=false
# Google口コミの「クチコミを書く」直リンク（GBP の共有リンク）。未設定でも動くが、入れると口コミ依頼文にリンクが載る。
FLATUP_GBP_REVIEW_URL=
# FlatポイントPRO の案内URL。未設定なら案内文は省略される。
FLATUP_POINT_PRO_URL=
