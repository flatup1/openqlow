# ===== FLATUP AI Animation Studio 環境変数 =====

# 実際にAI動画を生成するための Google Gemini / Veo APIキー(サーバー側だけで使用)。
# ※ 絶対にフロントエンドへ出さないこと。VITE_ / NEXT_PUBLIC_ の接頭辞は付けない。
GEMINI_API_KEY=

# 使用する動画生成モデル名。公式仕様が変わっている場合があるので必ず確認して設定する。
VIDEO_MODEL=veo-3.1-lite-generate-preview

# デモモード。true にすると APIキー無しでもサンプル動画でUIを確認できる。
# 本番では必ず false にすること。
VIDEO_GENERATION_DEMO_MODE=true

# サーバーのポート
PORT=8787

# 1IPあたりの生成リクエスト上限(15分あたり)
RATE_LIMIT_MAX=20

# アップロード画像の最大サイズ(バイト)。既定 10MB。
MAX_UPLOAD_BYTES=10485760

# 生成物・一時ファイルの保持時間(分)。過ぎたら自動削除。
ARTIFACT_TTL_MINUTES=60
