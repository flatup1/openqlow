# 依存
node_modules/

# ビルド成果物（npm run build で生成、本番は dist を node で実行）
dist/

# ランタイム生成物（VPS と Mac で別物、コミットしない）
/state/
drafts/
logs/
*.log

# CRM ランタイムデータ（見込み客PII・日報は個人情報を含むためコミットしない）
data/
reports/

# 機密
.env
.env.*
!.env.example

# 一時バックアップ
.phase2-backup/

# OS
.DS_Store
Thumbs.db

# エディタ
.vscode/
.idea/
*.swp

# Obsidian ミラー（誤同期防止）
obsidian-bridge/

# 自己改善ループの日次出力（latest-scorecard.json はベースラインとして追跡）
knowledge/sources/loop/scorecard-*.md
knowledge/sources/loop/improvement-*.md
knowledge/_inbox/

# --- FLATUP GYM AI OS ---
# 既存ファイル変更前の退避バックアップ
.ai-os-backup/
# AI OS のプライベート資料・ローカルログ
docs/ai-os/private/
docs/ai-os/logs/*.local.*
# 顧客個人情報・名簿・健康情報（Git管理しない）
*会員名簿*
*顧客*.csv
members*.csv
customers*.csv
health*.csv
# 認証・秘密情報
*.token
*_secret*
credentials*.json
