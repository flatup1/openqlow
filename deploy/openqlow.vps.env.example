# OPENQLOW VPS environment
# Copy to /etc/openqlow/openqlow.env on the VPS and fill secrets there.
# Do not commit real tokens.

NODE_ENV=production

# OPENQLOW lives separately from the existing FLATUP LINE Bot.
OPENQLOW_ROOT=/opt/openqlow
OPENQLOW_DATA_DIR=/home/flatup/openqlow-data
OPENQLOW_LINE_PORT=8787
OPENQLOW_DRY_RUN=true
OPENQLOW_LINE_DRY_RUN=false

# Optional: if the existing flatup-ai-os data is copied onto the VPS.
FLATUP_AI_OS_ROOT=/opt/flatup-ai-os

# Optional: if the Obsidian Vault is synced/mounted on the VPS.
OBSIDIAN_VAULT_ROOT=/opt/obsidian-vault
OPENQLOW_INBOX_RELATIVE=30_INBOX/openqlow

# Existing local Typefully config path is not used on VPS unless explicitly installed.
TYPEFULLY_CONFIG_PATH=/etc/openqlow/typefully.json

# OPENQLOW専用LINE公式アカウントの値を入れる。既存BOTの値と混ぜない。
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
JIN_LINE_USER_ID=
BACKUP_APPROVER_LINE_USER_ID=

# Optional health checks.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENQLOW_PUBLIC_WEBHOOK_URL=https://example.com/openqlow/webhook

# Optional local LLM layer on the VPS.
# Keep Ollama bound to localhost unless you intentionally add auth/reverse proxy.
OPENQLOW_LOCAL_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
OPENQLOW_CHECK_OLLAMA=false

# Optional AnythingLLM knowledge UI/API on the same VPS.
# Run it behind localhost or protected VPN/basic auth; do not expose it naked.
ANYTHINGLLM_BASE_URL=http://127.0.0.1:3001
ANYTHINGLLM_API_KEY=
OPENQLOW_CHECK_ANYTHINGLLM=false
