#!/usr/bin/env bash
# pre-commit hook：git-secrets チェックのみ（既存セキュリティ機構を維持）
#
# AI プレフィックスと領域チェックは commit-msg hook で行う
# （pre-commit はメッセージにアクセスできないため）

set -euo pipefail

if command -v git-secrets >/dev/null 2>&1; then
  git secrets --pre_commit_hook -- "$@" || {
    echo "❌ pre-commit: git-secrets でシークレット検出" >&2
    exit 1
  }
fi
