#!/usr/bin/env bash
# Claude/Codex 協業のための commit-msg フック
# COORDINATION.md の規約に従って、コミットメッセージと変更領域を検証する
#
# commit-msg hook は $1 にメッセージファイルパスを受け取る
# pre-commit と違い、ここでは確定したメッセージにアクセスできる

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
COMMIT_MSG_FILE="$1"

if [[ ! -f "${COMMIT_MSG_FILE}" ]]; then
  echo "❌ commit-msg: メッセージファイルが見つかりません" >&2
  exit 1
fi

FIRST_LINE=$(head -n 1 "${COMMIT_MSG_FILE}" | head -c 200)

# ===== 1. AI プレフィックス検証 =====

if ! echo "${FIRST_LINE}" | grep -qE "^(claude|codex|co-ai|jin):"; then
  echo "❌ コミットメッセージに AI プレフィックスがありません" >&2
  echo "" >&2
  echo "現在のメッセージ: ${FIRST_LINE}" >&2
  echo "" >&2
  echo "先頭を以下のいずれかにしてください：" >&2
  echo "  claude: ...  (Claudeが書いた)" >&2
  echo "  codex: ...   (Codexが書いた)" >&2
  echo "  co-ai: ...   (両AI共同・共通インフラ)" >&2
  echo "  jin: ...     (JIN手作業)" >&2
  echo "" >&2
  echo "規約：COORDINATION.md §6" >&2
  exit 1
fi

AI_PREFIX=$(echo "${FIRST_LINE}" | cut -d: -f1)

# ===== 2. 担当領域チェック =====

if [[ "${AI_PREFIX}" == "co-ai" ]] || [[ "${AI_PREFIX}" == "jin" ]]; then
  echo "✅ commit-msg: ${AI_PREFIX} prefix OK (no territory check)"
  exit 0
fi

COORD_FILE="${REPO_ROOT}/COORDINATION.md"
if [[ ! -f "${COORD_FILE}" ]]; then
  echo "⚠️  COORDINATION.md なし、領域チェックスキップ" >&2
  exit 0
fi

CHANGED_FILES=$(git diff --cached --name-only)
if [[ -z "${CHANGED_FILES}" ]]; then
  exit 0
fi

if [[ "${AI_PREFIX}" == "claude" ]]; then
  ALLOWED_PATTERNS="^(src/sources/|src/distribution/|src/generators/|COORDINATION\\.md|AGENTS\\.md|docs/|CLAUDE\\.md|HANDOFF)"
  OTHER_AI="codex"
elif [[ "${AI_PREFIX}" == "codex" ]]; then
  ALLOWED_PATTERNS="^(src/scheduler/|src/monitor/|src/line_bot/|src/safety/|src/approval/|src/commands/|src/publish/|src/adapters/|src/conversation/|src/state/|src/privacy/|deploy/|scripts/|COORDINATION\\.md|AGENTS\\.md|docs/|HANDOFF)"
  OTHER_AI="claude"
fi

VIOLATIONS=""
while IFS= read -r file; do
  if ! echo "${file}" | grep -qE "${ALLOWED_PATTERNS}"; then
    VIOLATIONS="${VIOLATIONS}  ${file}"$'\n'
  fi
done <<< "${CHANGED_FILES}"

if [[ -n "${VIOLATIONS}" ]]; then
  echo "❌ ${AI_PREFIX} の担当外領域に変更が含まれています" >&2
  echo "" >&2
  echo "違反ファイル:" >&2
  echo "${VIOLATIONS}" >&2
  echo "" >&2
  echo "対応：" >&2
  echo "  - 共通インフラなら 'co-ai:' プレフィックスに変更" >&2
  echo "  - JINの手作業なら 'jin:' プレフィックスに変更" >&2
  echo "  - 担当変更なら JIN に依頼して COORDINATION.md §1 更新" >&2
  exit 1
fi

echo "✅ commit-msg: ${AI_PREFIX} territory check passed"
